# Talksy Environment Variables
# Copy this file to .env and fill in your values

# App Settings
APP_NAME=Talksy
DEBUG=true
ENVIRONMENT=development
SECRET_KEY=your-secret-key-change-in-production

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Database - PostgreSQL (primary) or SQLite (dev convenience)
# Set DB_ENGINE=sqlite for local development without PostgreSQL
DB_ENGINE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=talksy
DB_USER=postgres
DB_PASSWORD=postgres
# DB_SQLITE_PATH=path/to/talksy.db  # Only needed if using sqlite

# OpenAI (for AI features)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Redis (optional)
REDIS_URL=redis://localhost:6379/0
