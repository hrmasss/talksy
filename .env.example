# Talksy Environment Variables
# Copy this file to .env and fill in your values

# App Settings
APP_NAME=Talksy
DEBUG=true
ENVIRONMENT=development
SECRET_KEY=your-secret-key-change-in-production

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Database - PostgreSQL (primary) or SQLite (dev convenience)
# Set DB_ENGINE=sqlite for local development without PostgreSQL
DB_ENGINE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=talksy
DB_USER=postgres
DB_PASSWORD=postgres
# DB_SQLITE_PATH=path/to/talksy.db  # Only needed if using sqlite

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# AI / LLM
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENROUTER_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_MODEL=
LLM_MODEL=openai/gpt-4.1-mini
GEMINI_API_KEY=

# Web Search (Tavily is tried first, Serper as fallback)
TAVILY_API_KEY=your-tavily-api-key-here
SERPER_API_KEY=

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=openai
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Qdrant – long-term memory vector store
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=talksy
QDRANT_EMBEDDING_DIM=1536

# AI Database (for LangGraph checkpointer)
AI_DB_URI=
